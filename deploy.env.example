# OPTIONAL deployment overrides for docker compose.
# Copy to ".env" next to docker-compose.yml and edit, THEN run `docker compose up -d`.
# (Skip this entirely and the defaults below are used — the app still works.)
#
#   cp deploy.env.example .env
#
# This file is read automatically by `docker compose`. It is NOT the Laravel
# .env — it only feeds the ${...} variables in docker-compose.yml.

# Public port on the server. Use 80 so the URL is just http://<your-ip>
APP_PORT=80

# Public address users visit. Used for links in emails and absolute URLs.
APP_URL=http://YOUR_DROPLET_IP

# Use a strong database password in production (any value; data is internal).
DB_PASSWORD=change-this-to-something-strong

# Mail: keep "smtp" to capture mail in the built-in Mailpit inbox, or set "log"
# to write mail to storage/logs, or configure a real provider in docker/app.env.
MAIL_MAILER=smtp
